# === Cloud Render ===
CLOUD_URL=https://zarzis-irrigation-1.onrender.com
API_TOKEN=zarzis_2026_irrigation_secret_938472
AGENT_ID=zarzis-edge-agent

# === DR302 Modbus ===
DR302_HOST=192.168.1.250
DR302_PORT=502
MODBUS_TIMEOUT_SEC=3.0

# === WebSocket + heartbeat ===
EDGE_WS_ENABLED=false
EDGE_HEARTBEAT_SEC=5
EDGE_STATUS_PUSH_SEC=2
EDGE_COMMAND_POLL_SEC=1

# === Buffer offline (chemins corrects user zarzis) ===
EDGE_DATA_DIR=/home/zarzis/zarzis-data
EDGE_LOG_DIR=/home/zarzis/zarzis-data/logs
EDGE_OFFLINE_BUFFER_ENABLED=true
EDGE_OFFLINE_MAX_ITEMS=10000

# === Autorisations (tout débloqué) ===
EDGE_ALLOW_START=true
SALMSON_COMMAND_ENABLED=true

# === Carte relais GPIO 8 zones ===
RELAY_ENABLED=true
RELAY_ACTIVE_LOW=true
RELAY_SIMULATION_ENABLED=false
RELAY_MAX_DURATION_MIN=120
RELAY_ZONE_1_PIN=17
RELAY_ZONE_2_PIN=27
RELAY_ZONE_3_PIN=22
RELAY_ZONE_4_PIN=23
RELAY_ZONE_5_PIN=24
RELAY_ZONE_6_PIN=25
RELAY_ZONE_7_PIN=5
RELAY_ZONE_8_PIN=6

# === Adresses Modbus ===
ADDR_INVT=1
ADDR_SALMSON=2
ADDR_WILO=3
ADDR_COFFRET4=4

# === Registres INVT ===
INVT_CMD_REG=0x1000
INVT_ON_VALUE=1
INVT_OFF_VALUE=0
INVT_NOMINAL_KW=5.5
INVT_REG_FREQ_HZ=0x3000
INVT_REG_SET_FREQ_HZ=0x3001
INVT_REG_DC_BUS_V=0x3002
INVT_REG_VOLTAGE_V=0x3003
INVT_REG_CURRENT_A=0x3004
INVT_REG_POWER_PCT=0x3006
INVT_REG_FAULT_CODE=0x5000

# === Registres Salmson ===
SALMSON_FLOAT_LOW_OK_VALUE=1
SALMSON_FLOAT_LOW_BIT=0
SALMSON_HIGH_WATER_BIT=4
SALMSON_CMD_REG=14
SALMSON_REG_LEVEL_CM=24
SALMSON_REG_PUMP1_MODE=40
SALMSON_REG_SWITCH_STATE=61
SALMSON_REG_ERROR_CODE=138
SALMSON_REG_FLOAT_STATE=197

# === Registres Wilo ===
WILO_CMD_REG=14
WILO_REG_PRESSURE=25
WILO_REG_FLOW=-1
WILO_REG_PUMP1_MODE=40
WILO_REG_PUMP2_MODE=41
WILO_REG_SWITCH_STATE=61
WILO_REG_ERROR_CODE=138
COFFRET4_REG_INPUT_1=0x0001
COFFRET4_REG_INPUT_2=0x0002
COFFRET4_REG_ANALOG_1=0x0010
COFFRET4_REG_ERROR_CODE=0x0020
INVT_REG_POWER_W=0x3005
INVT_REG_TEMP_C=0x3007
